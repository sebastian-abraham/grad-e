# =========================
# Secrets & Environment
# =========================
.env
.env.*
!.env.example

# =========================
# Python & Virtual Env
# =========================
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
build/
dist/

# =========================
# grad-e Dynamic Storage Files
# =========================
# Ignore all dynamically generated inputs, crops, and reports
engine/storage/crops/
engine/storage/inputs/
engine/storage/reports/
engine/storage/local/

# Specifically ignore the Byaldi index folder and temporary local assets
.byaldi/
engine/storage/local/temp_qp_pages/

# Exception: Keep .gitkeep files to ensure empty directory structure is tracked
!engine/storage/crops/.gitkeep
!engine/storage/inputs/.gitkeep
!engine/storage/reports/.gitkeep
!engine/storage/local/.gitkeep
!engine/storage/local/temp_qp_pages/.gitkeep

# =========================
# IDE & OS Specific
# =========================
.vscode/
.idea/
.DS_Store
Thumbs.db
*.log